# =====================================================
# UniHR SaaS — .gitignore
# =====================================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
.eggs/

# ---------- 虛擬環境 ----------
.venv/
venv/
env/
ENV/

# ---------- 測試快取 ----------
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/

# ---------- 環境變數（只保留 .env.example）----------
.env
.env.local
.env.development
.env.staging
.env.production

# ---------- 上傳資料（保留目錄結構）----------
uploads/*
!uploads/.gitkeep

# ---------- 編輯器 / IDE ----------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------- 作業系統 ----------
.DS_Store
Thumbs.db
._*

# ---------- 前端建置產出 ----------
dist/
build/
node_modules/
*.log
*.tsbuildinfo
frontend/playwright-report/
frontend/test-results/
frontend/dist.zip

# ---------- Docker ----------
*.tar

# ---------- 其他 ----------
*.bak
*.tmp
test_*.txt

# ---------- 測試結果原始跑次（保留命名版本）----------
test-data/test-results/run_*/
test-data/test-results/live_*/
test-data/test-results/*.json

# ---------- 個人資料保護（PDPA）：禁止提交任何公司文件資料 ----------
# 以下目錄含真實姓名、身分證號、薪資、健康紀錄等個人敏感資料
# 若需測試資料，請使用完全虛構的匿名資料替代
test-data/company-documents/
test-data/test-results/

# ---------- 一次性工具腳本 ----------
scripts/_fix_secrets.py
