# Application Settings
APP_NAME=UniHR SaaS
APP_ENV=development
API_V1_STR=/api/v1
SECRET_KEY=change_this_to_a_secure_random_string
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=<CHANGE_ME_MIN_12_CHARS>

# Core API (Legacy Labor Law System)
CORE_API_URL=http://localhost:5000
CORE_SERVICE_TOKEN=your_service_token_here

# Gemini
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash-preview

# LLM Backend (gemini / core)
LLM_BACKEND=gemini

# Source Arbitration (policy vs labor-law)
SOURCE_PRIORITY_MODE=adaptive
POLICY_SOURCE_WEIGHT=0.65
LAW_SOURCE_WEIGHT=0.35
CONFLICT_RESOLUTION_MODE=legal_floor

# Voyage AI (Embeddings + pgvector)
VOYAGE_API_KEY=voyage-...
VOYAGE_MODEL=voyage-4-lite

# Database (PostgreSQL)
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=unihr_saas

# Redis (Queue & Cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# LlamaParse (Document Parsing)
LLAMAPARSE_ENABLED=true
LLAMAPARSE_API_KEY=
LLAMAPARSE_LANGUAGE=zh-TW

# OCR
OCR_LANGS=chi_tra+eng
